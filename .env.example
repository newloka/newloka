# New Loka Environment Configuration

# Database
NEWLOKA_DB_PATH=newloka.db

# Node Identity
NEWLOKA_NODE_ID=local-node
NEWLOKA_TIER=t0

# Server (T1+)
NEWLOKA_BIND_ADDR=127.0.0.1:8080

# Logging
NEWLOKA_LOG_LEVEL=info

# Audit
NEWLOKA_AUDIT_MODE=strict

# Sync
NEWLOKA_SYNC_INTERVAL_SECONDS=300
NEWLOKA_MESH_DISCOVERY=true
